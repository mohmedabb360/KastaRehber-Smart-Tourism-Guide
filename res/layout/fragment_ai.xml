<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F6F0"
    android:layoutDirection="ltr">

    <!-- الـ TopBar المحدث بدعم اللاما الرسمي -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/aiTopBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="48dp"
        android:paddingBottom="16dp"
        android:paddingHorizontal="24dp"
        android:background="#052012"
        android:elevation="4dp"
        android:layout_alignParentTop="true">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Kastamonu AI Rehberi"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Llama 3.3 Destekli"
            android:textColor="#C5A059"
            android:textSize="12sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvTitle"
            android:layout_marginTop="2dp"/>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <LinearLayout
        android:id="@+id/layoutInputArea"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:background="#FFFFFF"
        android:gravity="center_vertical"
        android:layout_alignParentBottom="true">

        <EditText
            android:id="@+id/etMessage"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:hint="Bir soru sorun..."
            android:textColorHint="#9E9E9E"
            android:textColor="#052012"
            android:textSize="15sp"
            android:paddingHorizontal="12dp"
            android:importantForAutofill="no"
            android:inputType="textLongMessage" />

        <ImageView
            android:id="@+id/btnSend"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_send"
            android:padding="8dp"
            app:tint="#C5A059"
            android:contentDescription="Send" />
    </LinearLayout>

    <!-- 🚀 تحديث الأسئلة المقترحة التفاعلية فوق خانة الكتابة -->
    <HorizontalScrollView
        android:id="@+id/layoutQuickReplies"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingHorizontal="16dp"
        android:paddingBottom="12dp"
        android:layout_above="@id/layoutInputArea"
        android:clipToPadding="false">

        <LinearLayout
            android:id="@+id/containerCapsules"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/capsuleKale"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🏰 Kaleye nasıl çıkılır?"
                android:textColor="#052012"
                android:textSize="13sp"
                android:background="@drawable/bottom_sheet_bg"
                android:backgroundTint="#FFFFFF"
                android:paddingHorizontal="14dp"
                android:paddingVertical="8dp"
                android:layout_marginEnd="8dp"
                android:elevation="2dp" />

            <TextView
                android:id="@+id/capsuleYemek"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🍲 En meşhur yöresel yemekler?"
                android:textColor="#052012"
                android:textSize="13sp"
                android:background="@drawable/bottom_sheet_bg"
                android:backgroundTint="#FFFFFF"
                android:paddingHorizontal="14dp"
                android:paddingVertical="8dp"
                android:layout_marginEnd="8dp"
                android:elevation="2dp" />

            <TextView
                android:id="@+id/capsuleKanyon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🌲 Valla Kanyonu nerede?"
                android:textColor="#052012"
                android:textSize="13sp"
                android:background="@drawable/bottom_sheet_bg"
                android:backgroundTint="#FFFFFF"
                android:paddingHorizontal="14dp"
                android:paddingVertical="8dp"
                android:elevation="2dp" />
        </LinearLayout>
    </HorizontalScrollView>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvChatStream"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp"
        android:clipToPadding="false"
        android:layout_below="@id/aiTopBar"
        android:layout_above="@id/layoutQuickReplies" />

</RelativeLayout>